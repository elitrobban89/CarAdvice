# Kopieras till .env för lokal utveckling — hårdkoda aldrig riktiga nycklar i koden

# Obligatorisk
GROQ_API_KEY=din_groq_nyckel_här
ADMIN_KEY=välj-ett-starkt-slumpmässigt-värde

# Databas (valfri lokalt — faller tillbaka på H2 in-memory om ej satt)
DB_URL=jdbc:postgresql://localhost:5432/caradvice
DB_USER=postgres
DB_PASS=

# Stripe (valfri lokalt — lämna tomma för att hoppa över betalfunktioner)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# App (valfri — default: http://localhost:8080)
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=https://elitrobban.se,http://localhost:8080
